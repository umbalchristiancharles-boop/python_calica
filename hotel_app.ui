             <property name="styleSheet">
              <string notr="true">/* This is the normal state you already have */
QPushButton#btn_delete {
    background-color: #e74c3c; 
    color: white;
    border: none;
    border-radius: 4px;
    padding: 8px 16px;
    font-weight: bold;
}

/* --- ADD THIS PART FOR THE HOVER --- */
QPushButton#btn_delete:hover {
    background-color: #c0392b; /* A slightly darker red */
}

/* Optional: This makes it even darker when you actually CLICK it */
QPushButton#btn_delete:pressed {
    background-color: #a93226;
}</string>
