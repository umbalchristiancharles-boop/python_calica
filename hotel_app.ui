      <widget class="QWidget" name="page_booking">
       <property name="styleSheet">
        <string notr="true">QGroupBox {
    font-size: 14px;
    font-weight: bold;
    color: #000000;
    border: 2px solid #dcdde1;
    border-radius: 10px;
    margin-top: 20px;
    padding: 10px;
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 15px;
    padding: 20px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    padding: 0 5px;
}

/* Style all Input Fields (LineEdits, Combo Boxes, and DateEdits) */
QLineEdit, QComboBox, QDateEdit, QSpinBox, QPlainTextEdit {
    border: 1px solid #ced4da;
    border-radius: 5px;
    padding: 5px;
    background-color: #f8f9fa;
    color: #333;
    font-size: 13px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 2px solid #3498db; /* Blue glow when typing */
    background-color: #fff;
}

/* Style the Labels */
QLabel {
    font-size: 13px;
    color: #34495e;
    font-weight: normal;
}

/* The Confirm Button */
QPushButton#btn_confirm {
    background-color: #27ae60;
    color: white;
    border-radius: 6px;
    font-weight: bold;
	min-height: 35px;
}

/* THE HOVER - Make sure there is NO space between the name and the colon */
QPushButton#btn_confirm:hover {
    background-color: #2ecc71; /* A lighter green */
}

/* The Back Button */
QPushButton#btn_back {
    background-color: rgba(255, 255, 255, 0.2); 
    color: #c0392b;
    border: 1px solid #c0392b;
    border-radius: 6px;
	min-height: 35px;
}

QPushButton#btn_back:hover {
    background-color: #c0392b;
    color: white;
}</string>
