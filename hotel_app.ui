       <property name="styleSheet">
        <string notr="true">/* Background of the Admin Page */
QWidget#page_admin {
    background-color: #f4f7f6;
}

/* Table Design */
QTableWidget {
    background-color: white;
    border: 1px solid #dcdfe3;
    gridline-color: #f0f0f0;
    border-radius: 5px;
}

QHeaderView::section {
    background-color: #34495e;
    color: white;
    padding: 6px;
    font-weight: bold;
    border: none;
}

/* Common Button Settings */
QPushButton {
    border-radius: 4px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 12px;
}

/* --- REFRESH BUTTON (Green) --- */
QPushButton#btn_refresh {
    background-color: #27ae60;
    color: white;
    border: none;
}
QPushButton#btn_refresh:hover {
    background-color: #2ecc71;
}

/* --- DELETE BUTTON (Red) --- */
QPushButton#btn_delete {
    background-color: #e74c3c;
    color: white;
    border: none;
}
QPushButton#btn_delete:hover {
    background-color: #ff5e4d;
}

/* --- LOGOUT BUTTON (Dark Grey/Professional) --- */
QPushButton#btn_logout {
    background-color: #95a5a6;
    color: white;
    border: none;
}
QPushButton#btn_logout:hover {
    background-color: #7f8c8d;
}

/* Search Bar Styling */
QLineEdit {
    border: 1px solid #bdc3c7;
    border-radius: 4px;
    padding: 5px;
    background-color: white;
}

/* Table Header Styling */
QHeaderView::section {
    background-color: #1a1a1a; /* Matches your Black title vibe */
    color: white;
    padding: 8px;
    font-weight: bold;
    border: none;
    border-right: 1px solid #333; /* Subtle divider */
}

/* Make the Total Bill column bold */
QTableWidget::item {
    padding: 5px;
}

/* Highlight the last column (Total Bill) */
QTableWidget::item:last-child {
    font-weight: bold;
    color: #27ae60; /* Money green */
}

/* LOGOUT BUTTON (Normal) */
QPushButton#btn_logout {
    background-color: #7f8c8d; /* Professional Slate Grey */
    color: white;
    border: none;
    border-radius: 4px;
    padding: 5px 15px;
    font-weight: bold;
}

/* LOGOUT BUTTON (Hover) */
QPushButton#btn_logout:hover {
    background-color: #95a5a6; /* Lighter grey so it &quot;lights up&quot; */
}

/* LOGOUT BUTTON (Pressed) */
QPushButton#btn_logout:pressed {
    background-color: #2c3e50; /* Deep blue-grey when clicked */
}</string>
