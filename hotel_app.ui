             <property name="styleSheet">
              <string notr="true">/* --- REFRESH BUTTON (Normal State - Green) --- */
QPushButton#btn_refresh {
    background-color: #27ae60; /* Emerald Green */
    color: white;
    border: none;
    border-radius: 4px;
    padding: 8px 16px;
    font-weight: bold;
}

/* REFRESH BUTTON (Hover State - Lighter Green) */
QPushButton#btn_refresh:hover {
    background-color: #2ecc71; /* Brighter Green */
}

/* REFRESH BUTTON (Pressed State - Darker Green) */
QPushButton#btn_refresh:pressed {
    background-color: #1e8449;
}</string>
